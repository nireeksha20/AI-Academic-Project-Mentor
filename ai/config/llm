import os
from dotenv import load_dotenv
from crewai import LLM

load_dotenv()

llm = LLM(
    model="gemini/gemini-2.5-flash-lite",
    api_key=os.getenv("GEMINI_API_KEY"),
    temperature=0.1,
    max_tokens=1800
)

try:
    print(llm.call("Hello"))
except Exception as e:
    import traceback
    traceback.print_exc()
